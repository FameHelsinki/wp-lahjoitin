{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "famehelsinki/donation-form",
	"version": "0.1.0",
	"title": "Lahjoitin",
	"category": "widgets",
	"description": "Gutenberg block for Fame donation system.",
	"example": {},
	"providesContext": {
		"famehelsinki/donation-types": "types"
	},
	"attributes": {
		"types": {
			"type": "array",
			"default": []
		},
		"colsDesktop": {
			"type": "number",
			"default": 3
		},
		"token": {
			"type": "boolean",
			"default": false
		},
		"campaign": {
			"type": "string",
			"default": ""
		},
		"returnAddress": {
			"type": "string",
			"default": "/"
		},
		"primaryColor": {
			"type": "string",
			"default": "#000000"
		},
		"secondaryColor": {
			"type": "string",
			"default": "#FFFFFF"
		},
		"thirdColor": {
			"type": "string",
			"default": "#444"
		},
		"textFieldBorderRadius": {
			"type": "string",
			"default": "0px"
		},
		"borderRadius": {
			"type": "string",
			"default": "0px"
		},
		"borderWidth": {
			"type": "string",
			"default": "1px"
		}
	},
	"supports": {
		"align": ["left", "right", "center", "full"],
		"color": {
			"background": false,
			"text": true
		},
		"spacing": {
			"margin": true
		},
		"html": false,
		"typography": {
			"fontSize": true
		}
	},
	"allowedBlocks": ["core/columns"],
	"icon": "money",
	"textdomain": "fame_lahjoitukset",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"viewScript": "file:./view.js",
	"style": "file:./view.css",
	"render": "file:./render.php"
}
