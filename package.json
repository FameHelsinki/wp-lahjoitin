{
	"name": "lahjoitin",
	"version": "1.0.0",
	"description": "Wordpress plugin for lahjoitukset backend.",
	"author": "Fame Helsinki",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"build": "wp-scripts build",
		"build:i18n": "npm run i18n:mo && npm run i18n:mo:aliases && npm run i18n:json",
		"i18n:pot": "npm run build && wp i18n make-pot . languages/fame_lahjoitukset.pot --domain=fame_lahjoitukset --exclude=node_modules,vendor,tests,.git",
		"i18n:mo": "wp i18n make-mo languages languages",
		"i18n:json": "wp i18n make-json languages languages --no-purge",
		"i18n": "npm run i18n:pot && npm run i18n:mo && npm run i18n:mo:aliases && npm run i18n:json",
		"format": "wp-scripts format src",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"test:unit": "wp-scripts test-unit-jest",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"dev": "wp-scripts start",
		"start": "npm run start",
		"i18n:mo:aliases": "cp languages/fame_lahjoitukset-fi_FI.mo languages/fame_lahjoitukset-fi.mo && cp languages/fame_lahjoitukset-sv_SE.mo languages/fame_lahjoitukset-sv.mo"
	},
	"devDependencies": {
		"@jest/globals": "^30.3.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.0",
		"@types/wordpress__block-editor": "^15.0.6",
		"@wordpress/api-fetch": "^7.21.1",
		"@wordpress/block-editor": "^15.21.1",
		"@wordpress/blocks": "^15.21.1",
		"@wordpress/components": "^35.0.1",
		"@wordpress/compose": "^8.1.1",
		"@wordpress/data": "^10.48.1",
		"@wordpress/dom-ready": "^4.48.1",
		"@wordpress/eslint-plugin": "^25.4.1",
		"@wordpress/i18n": "^6.21.1",
		"@wordpress/prettier-config": "^4.48.1",
		"@wordpress/scripts": "^32.6.0",
		"eslint-config-prettier": "^10.1.8",
		"prettier": "^3.8.1"
	},
	"dependencies": {
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	}
}
